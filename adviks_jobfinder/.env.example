# ── Supabase (backend uses service role; get keys from Dashboard → Settings → API) ──
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── App URLs ──
FRONTEND_URL=http://localhost:3000

# ── Playwright autofill (optional) ──
INTERNMATCH_PROFILE_DIR=C:\Users\YOUR_USER\.internmatch-chrome

# ── Job scraping ──
# Indeed is the most reliable. Others (linkedin/glassdoor/zip_recruiter) often
# return 403 / require auth. Add at your own risk.
JOB_SITES=indeed

# ── LLM (cloud, fast) ──────────────────────────────────────────────────────
# Set LLM_PROVIDER=nvidia to use NVIDIA-hosted models, or "ollama" for local.
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
LLM_MAX_TOKENS=700
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.7
# Other good options on NVIDIA: qwen/qwen3-next-80b-a3b-instruct,
# nvidia/llama-3.1-nemotron-70b-instruct, openai/gpt-oss-120b

# ── Ollama (only used for embeddings now) ─────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
USE_OLLAMA_EMBEDDINGS=false

# ── Job Discovery (Adzuna + RemoteOK) ───────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# ── Email Apply ──────────────────────────────────────────────────────────────
# Option A — Gmail / normal inbox (no custom domain required):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM=you@gmail.com

# Option B — Resend (requires a verified custom domain; gmail.com will NOT work):
# RESEND_API_KEY=re_...
# EMAIL_FROM=applications@yourdomain.com
